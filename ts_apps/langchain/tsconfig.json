// refer: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html
{
  "compilerOptions": {
    /* Language */
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    /* Module */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Paths */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Output */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Emit */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Performance */
    "skipLibCheck": true,

    /* Misc */
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    /* Others */
    "jsx": "preserve",
    "pretty": true,
    "noImplicitThis": true,
    "removeComments": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
